# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# Docker/Postgres settings
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# DATABASE_URL: Connection string for Prisma/PostgreSQL
DATABASE_URL=

# API server port (harus berbeda dengan port frontend Vite: 5173)
API_PORT=

# Admin login credentials (used by backend endpoint)
ADMIN_USERNAME=
ADMIN_PASSWORD=
