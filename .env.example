# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# Docker/Postgres settings
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# DATABASE_URL: Connection string for Prisma/PostgreSQL
DATABASE_URL=

# NODE_ENV: gunakan production di server deploy
NODE_ENV=

# API server port (harus berbeda dengan port frontend Vite: 5173)
API_PORT=

# CORS_ORIGIN: daftar origin frontend yang diizinkan akses API backend
# pisahkan dengan koma, contoh: http://localhost:5173,https://app-anda.vercel.app
# mendukung wildcard, contoh: https://*.vercel.app
CORS_ORIGIN=

# Admin login credentials (used by backend endpoint)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# VITE_API_BASE_URL: opsional untuk frontend production (mis. Vercel)
# contoh: https://api.domain-anda.com
# untuk dev lokal bisa dikosongkan agar tetap pakai proxy /api
VITE_API_BASE_URL=
